{
  "identifier": "com.aiko.ai-text-tools",
  "name": {
    "en": "AI Text Tools",
    "zh-hans": "AI 文本工具"
  },
  "icon": "expand.svg",
  "popclipVersion": 3785,
  "description": {
    "en": "AI-powered text tools: expand, shorten, polish, translate, and custom prompt.",
    "zh-hans": "AI 文本工具：扩写、缩写、润色、翻译和自定义提示词。"
  },
  "entitlements": [
    "network"
  ],
  "actions": [
    {
      "identifier": "expand",
      "title": {
        "en": "Expand",
        "zh-hans": "扩写"
      },
      "icon": "expand.svg",
      "shellScriptFile": "ai-request.sh",
      "after": "paste-result",
      "stoppable": true,
      "requirements": [
        "text",
        "option-enableExpand=1"
      ]
    },
    {
      "identifier": "shorten",
      "title": {
        "en": "Shorten",
        "zh-hans": "缩写"
      },
      "icon": "shorten.svg",
      "shellScriptFile": "ai-request.sh",
      "after": "paste-result",
      "stoppable": true,
      "requirements": [
        "text",
        "option-enableShorten=1"
      ]
    },
    {
      "identifier": "polish",
      "title": {
        "en": "Polish",
        "zh-hans": "润色"
      },
      "icon": "polish.svg",
      "shellScriptFile": "ai-request.sh",
      "after": "paste-result",
      "stoppable": true,
      "requirements": [
        "text",
        "option-enablePolish=1"
      ]
    },
    {
      "identifier": "translate",
      "title": {
        "en": "Translate",
        "zh-hans": "翻译"
      },
      "icon": "translate.svg",
      "shellScriptFile": "ai-request.sh",
      "after": "paste-result",
      "stoppable": true,
      "requirements": [
        "text",
        "option-enableTranslate=1"
      ]
    },
    {
      "identifier": "custom",
      "title": {
        "en": "Custom",
        "zh-hans": "自定义"
      },
      "icon": "custom.svg",
      "shellScriptFile": "ai-request.sh",
      "after": "paste-result",
      "stoppable": true,
      "requirements": [
        "text",
        "option-enableCustom=1"
      ]
    }
  ],
  "options": [
    {
      "identifier": "provider",
      "label": {
        "en": "AI Provider",
        "zh-hans": "AI 提供商"
      },
      "type": "multiple",
      "values": [
        "openai",
        "claude"
      ],
      "valueLabels": [
        "OpenAI Compatible",
        "Claude (Anthropic)"
      ]
    },
    {
      "identifier": "apiBaseUrl",
      "label": {
        "en": "API Base URL",
        "zh-hans": "API 地址"
      },
      "type": "string",
      "defaultValue": "https://api.openai.com/v1",
      "description": {
        "en": "Base URL for the API endpoint",
        "zh-hans": "API 接口的基础地址"
      }
    },
    {
      "identifier": "apiKey",
      "label": {
        "en": "API Key",
        "zh-hans": "API 密钥"
      },
      "type": "string",
      "description": {
        "en": "Your API key for authentication",
        "zh-hans": "用于身份验证的 API 密钥"
      }
    },
    {
      "identifier": "model",
      "label": {
        "en": "Model",
        "zh-hans": "模型"
      },
      "type": "string",
      "defaultValue": "gpt-5-nano",
      "description": {
        "en": "Model name, e.g. gpt-5-nano, claude-haiku-4-6-20250612",
        "zh-hans": "模型名称，如 gpt-5-nano、claude-haiku-4-6-20250612"
      }
    },
    {
      "identifier": "outputMode",
      "label": {
        "en": "Output Mode",
        "zh-hans": "输出方式"
      },
      "type": "multiple",
      "values": [
        "replace",
        "copy"
      ],
      "valueLabels": [
        "Replace selected text",
        "Copy to clipboard"
      ],
      "defaultValue": "replace"
    },
    {
      "identifier": "customPrompt",
      "label": {
        "en": "Custom Prompt",
        "zh-hans": "自定义提示词"
      },
      "type": "string",
      "defaultValue": "请帮我处理以下文本",
      "description": {
        "en": "Prompt for the Custom action. Selected text will be appended.",
        "zh-hans": "自定义操作的提示词，选中文本会附在后面。"
      }
    },
    {
      "identifier": "enableExpand",
      "label": {
        "en": "Enable Expand",
        "zh-hans": "启用 扩写"
      },
      "type": "boolean",
      "defaultValue": true,
      "icon": "expand.svg"
    },
    {
      "identifier": "enableShorten",
      "label": {
        "en": "Enable Shorten",
        "zh-hans": "启用 缩写"
      },
      "type": "boolean",
      "defaultValue": true,
      "icon": "shorten.svg"
    },
    {
      "identifier": "enablePolish",
      "label": {
        "en": "Enable Polish",
        "zh-hans": "启用 润色"
      },
      "type": "boolean",
      "defaultValue": true,
      "icon": "polish.svg"
    },
    {
      "identifier": "enableTranslate",
      "label": {
        "en": "Enable Translate",
        "zh-hans": "启用 翻译"
      },
      "type": "boolean",
      "defaultValue": true,
      "icon": "translate.svg"
    },
    {
      "identifier": "enableCustom",
      "label": {
        "en": "Enable Custom",
        "zh-hans": "启用 自定义"
      },
      "type": "boolean",
      "defaultValue": true,
      "icon": "custom.svg"
    }
  ]
}